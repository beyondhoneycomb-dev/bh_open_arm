# ── Local tooling / session state (never commit) ───────────────
.remember/
.serena/
.claude/
.impeccable/

# ── Secrets & environment ──────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.eggs/
build/
dist/
.venv/
venv/
# Root-anchored: this ignores a repo-root `env/` virtualenv, not the tracked
# WP-ENV-04 code path `registry/env/` (02a §2.2). An unanchored `env/` matched both.
/env/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
# `uv.lock` is a committed deliverable (WP-ENV-02): env_hash folds in the lock
# hash, so reproducibility across clones requires the lock in the tree.

# ── Node / Web frontend (web SPA) ──────────────────────────────
node_modules/
.next/
.turbo/
.vite/
frontend/dist/
frontend/build/
*.tsbuildinfo
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

